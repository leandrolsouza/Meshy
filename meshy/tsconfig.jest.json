{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "jsx": "react-jsx",
        "lib": [
            "ES2020",
            "dom"
        ],
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "outDir": "dist-jest",
        "rootDir": ".",
        "skipLibCheck": true,
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "main/**/*",
        "src/**/*",
        "tests/**/*",
        "electron/**/*",
        "shared/**/*"
    ],
    "exclude": [
        "node_modules",
        "out"
    ]
}