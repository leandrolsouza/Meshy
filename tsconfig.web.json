{
    "compilerOptions": {
        "composite": true,
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "outDir": "out/renderer",
        "baseUrl": ".",
        "paths": {
            "@renderer/*": ["src/*"]
        }
    },
    "include": ["src/**/*", "shared/**/*"]
}
